# Server
PORT=3000
API_VERSION=1.0.0

# Authentication
# AUTH_MODE: "apikey" (default) or "none" (open, dev only)
AUTH_MODE=apikey
API_KEY=changeme-set-a-strong-key-here

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
RATE_LIMIT_MAX=100            # max requests per window per IP

# File upload
MAX_FILE_SIZE_MB=50           # max upload size in MB
